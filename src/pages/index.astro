---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import StarMap from '../components/StarMap';
import { getCollection } from 'astro:content';

// Tailwind's JIT scans for literal class strings — dynamic `text-${color}-300`
// interpolation wouldn't get picked up, so each badge spells its classes out in full.
const badgeStyles = {
	Garden: {
		icon: 'fa-seedling',
		label: 'text-emerald-300',
		iconColor: 'text-emerald-200/50 group-hover:text-emerald-200',
		hoverTitle: 'group-hover:text-emerald-300',
		gradient: 'from-emerald-900/40 via-slate-900 to-slate-900',
	},
	Lab: {
		icon: 'fa-flask',
		label: 'text-amber-300',
		iconColor: 'text-amber-200/50 group-hover:text-amber-200',
		hoverTitle: 'group-hover:text-amber-300',
		gradient: 'from-amber-900/40 via-purple-900/20 to-slate-900',
	},
	Thoughts: {
		icon: 'fa-feather-alt',
		label: 'text-blue-300',
		iconColor: 'text-blue-200/50 group-hover:text-blue-200',
		hoverTitle: 'group-hover:text-blue-300',
		gradient: 'from-blue-900/40 via-slate-900 to-slate-900',
	},
} as const;

const [garden, lab, thoughts] = await Promise.all([
	getCollection('garden'),
	getCollection('lab'),
	getCollection('thoughts'),
]);

const growingItems = [
	...garden.map((e) => ({
		title: e.data.title,
		description: e.data.description,
		href: `/garden/${e.slug}/`,
		badge: 'Garden' as const,
		heroImage: undefined as string | undefined,
		date: e.data.updatedDate,
	})),
	...lab.map((e) => ({
		title: e.data.title,
		description: e.data.description,
		href: `/lab/${e.slug}/`,
		badge: 'Lab' as const,
		heroImage: e.data.heroImage,
		date: e.data.pubDate,
	})),
	...thoughts.map((e) => ({
		title: e.data.title,
		description: e.data.description,
		href: `/thoughts/${e.slug}/`,
		badge: 'Thoughts' as const,
		heroImage: e.data.heroImage,
		date: e.data.pubDate,
	})),
]
	.sort((a, b) => b.date.valueOf() - a.date.valueOf())
	.slice(0, 4);
---

<Layout
	title="Between Binary | Digital Garden"
	description="A digital garden for cultivating immersive tech — VR experiments, embedded systems, parkour logs, and notes on human-centered design."
>
	<Header />
	<main class="relative pt-32 pb-20 px-6 font-sans">
		<div class="relative max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center min-h-[60vh]">
			<!-- Hero content — z-10 keeps text above stars; pointer-events-none lets hover pass through to stars behind text -->
			<div class="space-y-8 z-10 pointer-events-none">
				<div class="inline-block px-4 py-1 text-xs font-mono text-amber-200 border border-amber-900/50 rounded-full bg-amber-900/10 tracking-widest">
					LABORATORY • NOTES • EXPERIMENTS
				</div>
				<h1 class="text-6xl md:text-8xl font-bold leading-tight tracking-tight text-white font-serif">
					Between <br>
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-[#FFD194] via-[#D1914B] to-[#70A1FF] drop-shadow-[0_0_30px_rgba(255,200,150,0.2)]">
						Binary
					</span>
				</h1>
				<p class="text-xl md:text-2xl text-slate-300 font-light max-w-lg leading-relaxed">
					A digital garden for cultivating immersive tech. <br>
					<span id="typed-output" class="text-amber-100/80 italic font-mono">Exploring the space properly.</span>
				</p>
				
				<script>
					const words = ["VR Experiments", "Learning Notes", "Parkour Logs", "System Prototypes"];
					const el = document.getElementById('typed-output');
					const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

					if (el && prefersReducedMotion) {
						el.textContent = words[0];
					} else if (el) {
						let wordIndex = 0;
						let charIndex = 0;
						let deleting = false;

						function tick() {
							const word = words[wordIndex];
							if (!deleting) {
								charIndex++;
								el.textContent = word.slice(0, charIndex);
								if (charIndex === word.length) {
									deleting = true;
									setTimeout(tick, 1400);
									return;
								}
							} else {
								charIndex--;
								el.textContent = word.slice(0, charIndex);
								if (charIndex === 0) {
									deleting = false;
									wordIndex = (wordIndex + 1) % words.length;
								}
							}
							setTimeout(tick, deleting ? 35 : 65);
						}
						tick();
					}
				</script>
				<div class="flex space-x-4 pt-6 pointer-events-auto">
					<a href="/lab/" class="px-8 py-3 bg-gradient-to-r from-amber-700 to-amber-600 hover:from-amber-600 hover:to-amber-500 text-white font-medium rounded-full transition-all shadow-lg shadow-amber-900/30 tracking-wide flex items-center gap-2">
						<i class="fas fa-flask"></i> Enter Lab
					</a>
					<a href="/garden/" class="px-8 py-3 bg-white/5 backdrop-blur-sm border border-white/10 hover:bg-white/10 text-white rounded-full transition-all font-light tracking-wide flex items-center gap-2">
						 <i class="fas fa-book-open"></i> Explore Notes
					</a>
				</div>
			</div>
			
			<!-- Star Map ──────────────────────────────────────────────────
			     Mobile (<lg): absolute bg behind hero, overflow-hidden clips stars
			     Desktop (lg+): normal grid column on right, overflow-visible lets
			     stars extend beyond column (page overflow-x-hidden prevents scrollbar)
			-->
			<div class="absolute inset-0 overflow-hidden lg:relative lg:inset-auto lg:overflow-visible lg:h-full lg:min-h-[500px]">
				<StarMap client:load />
			</div>
		</div>

		<!-- Pillars / Recent Posts -->
		<div class="max-w-7xl mx-auto mt-24">
			<h2 class="text-2xl font-light mb-10 tracking-widest text-amber-200/60 uppercase text-center">
				<i class="fas fa-seedling mr-2"></i> Growing Ideas
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				{growingItems.map((item) => {
					const style = badgeStyles[item.badge];
					return (
						<a href={item.href} class="bg-white/5 backdrop-blur-md border border-white/5 p-6 rounded-2xl flex flex-col h-full cursor-pointer hover:transform hover:-translate-y-2 transition-all duration-300 hover:shadow-[0_20px_40px_-10px_rgba(0,0,0,0.3)] hover:bg-white/10 group">
							<div
								class={`h-40 w-full rounded-xl mb-4 overflow-hidden relative bg-gradient-to-br ${style.gradient}`}
								style={item.heroImage ? `background-image: url('${item.heroImage}'); background-size: cover; background-position: center;` : undefined}
							>
								<div class={`absolute bottom-3 left-4 text-xs font-bold tracking-widest ${style.label} uppercase`}>{item.badge}</div>
								<div class="absolute top-3 right-4">
									<i class={`fas ${style.icon} text-xl transition-all duration-300 group-hover:scale-110 ${style.iconColor}`}></i>
								</div>
							</div>
							<h3 class={`text-lg font-medium mb-3 text-white leading-snug transition-colors ${style.hoverTitle}`}>{item.title}</h3>
							<p class="text-slate-400 text-sm flex-grow font-light leading-relaxed line-clamp-2">{item.description}</p>
						</a>
					);
				})}
			</div>
		</div>
	</main>
</Layout>
