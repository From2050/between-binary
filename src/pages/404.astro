---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout
	title="Lost in the Void | Between Binary"
	description="This page drifted out of orbit — it doesn't exist."
>
	<Header />

	<main class="relative flex flex-col items-center justify-center min-h-screen px-6 text-center pt-32 pb-20">
		<div class="inline-block px-4 py-1 text-xs font-mono text-amber-200 border border-amber-900/50 rounded-full bg-amber-900/10 tracking-widest mb-8">
			SIGNAL LOST
		</div>
		<h1 class="text-7xl md:text-9xl font-bold font-serif text-transparent bg-clip-text bg-gradient-to-r from-[#FFD194] via-[#D1914B] to-[#70A1FF] mb-6">
			404
		</h1>
		<p class="text-xl md:text-2xl text-slate-300 font-light max-w-lg mb-10 leading-relaxed">
			This star has drifted out of orbit. The page you're looking for doesn't exist in this constellation.
		</p>
		<a href="/" class="px-8 py-3 bg-gradient-to-r from-amber-700 to-amber-600 hover:from-amber-600 hover:to-amber-500 text-white font-medium rounded-full transition-all shadow-lg shadow-amber-900/30 tracking-wide flex items-center gap-2">
			<i class="fas fa-arrow-left"></i> Return to Orbit
		</a>
	</main>
</Layout>
